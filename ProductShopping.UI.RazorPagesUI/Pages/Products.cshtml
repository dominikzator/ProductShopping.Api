@page
@model ProductsModel

<div class="page-alert-layer" id="pageAlertLayer">
    @if (!string.IsNullOrWhiteSpace(Model.FlashMessage))
    {
        <div class="page-alert page-alert--@(Model.FlashMessageType ?? "info")" data-auto-dismiss="true" role="alert">
            <span class="page-alert-text">@Model.FlashMessage</span>
            <button type="button" class="page-alert-close" data-alert-close aria-label="Zamknij komunikat">×</button>
        </div>
    }
</div>

<section class="products-page">
    <header class="products-header">
        <div>
            <p class="products-eyebrow">Catalog</p>
            <h1 class="products-title">Products</h1>
            <p class="products-subtitle">
                Browse available items and add them to your cart.
            </p>
        </div>

        <div class="products-summary">
            <span class="summary-label">Items on page</span>
            <strong>@(Model.Products?.Data?.Count() ?? 0)</strong>
        </div>
    </header>

    <form method="get" class="filters-toolbar">
        <input type="hidden" name="Query.PageNumber" value="1" />

        <div class="filters-search">
            <input type="text"
                   name="Query.Search"
                   value="@Model.Query.Search"
                   class="filters-search-input"
                   placeholder="Search products..." />
        </div>

        <div class="filters-actions">
            <div class="filter-dropdown" data-dropdown>
                <button type="button" class="filter-chip" data-dropdown-trigger>
                    Sort
                    <span class="filter-caret">⌄</span>
                </button>

                <div class="filter-menu filter-menu--form" data-dropdown-menu>
                    <label class="filter-label">Sort by</label>
                    <div class="filter-select-wrap">
                        <select name="Query.SortBy" class="filter-select">
                            <option value="Name" selected="@(Model.Query.SortBy == "Name")">Name</option>
                            <option value="Price" selected="@(Model.Query.SortBy == "Price")">Price</option>
                            <option value="Rating" selected="@(Model.Query.SortBy == "Rating")">Rating</option>
                            <option value="Category" selected="@(Model.Query.SortBy == "Category")">Category</option>
                        </select>
                    </div>

                    <label class="filter-checkbox">
                        <input asp-for="Query.SortDescending" type="checkbox" />
                        <span>Descending</span>
                    </label>

                    <button type="submit" class="filter-apply">Apply</button>
                </div>
            </div>

            <div class="filter-dropdown" data-dropdown>
                <button type="button" class="filter-chip" data-dropdown-trigger>
                    Category
                    <span class="filter-caret">⌄</span>
                </button>

                <div class="filter-menu filter-menu--form" data-dropdown-menu>
                    <label class="filter-label">Category</label>
                    <div class="filter-select-wrap">
                        <select asp-for="Query.CategoryName" class="filter-select">
                            <option value="">All categories</option>
                            @foreach (var category in Model.CategoryOptions)
                            {
                                <option value="@category">@category</option>
                            }
                        </select>
                    </div>

                    <button type="submit" class="filter-apply">Apply</button>
                </div>
            </div>

            <div class="filter-dropdown" data-dropdown>
                <button type="button" class="filter-chip" data-dropdown-trigger>
                    Price
                    <span class="filter-caret">⌄</span>
                </button>

                <div class="filter-menu filter-menu--form" data-dropdown-menu>
                    <label class="filter-label">Min price</label>
                    <input type="text"
                           name="Query.MinPrice"
                           value="@Model.Query.MinPrice"
                           class="filter-input"
                           placeholder="0" />

                    <label class="filter-label">Max price</label>
                    <input type="text"
                           name="Query.MaxPrice"
                           value="@Model.Query.MaxPrice"
                           class="filter-input"
                           placeholder="9999" />

                    <button type="submit" class="filter-apply">Apply</button>
                </div>
            </div>

            <div class="filter-dropdown" data-dropdown>
                <button type="button" class="filter-chip" data-dropdown-trigger>
                    Rating
                    <span class="filter-caret">⌄</span>
                </button>

                <div class="filter-menu filter-menu--form" data-dropdown-menu>
                    <label class="filter-label">Min rating</label>
                    <input type="text"
                           name="Query.MinRating"
                           value="@Model.Query.MinRating"
                           class="filter-input"
                           placeholder="0.0" />

                    <label class="filter-label">Max rating</label>
                    <input type="text"
                           name="Query.MaxRating"
                           value="@Model.Query.MaxRating"
                           class="filter-input"
                           placeholder="5.0" />

                    <button type="submit" class="filter-apply">Apply</button>
                </div>
            </div>

            <div class="filter-dropdown" data-dropdown>
                <button type="button" class="filter-chip" data-dropdown-trigger>
                    Page size
                    <span class="filter-caret">⌄</span>
                </button>

                <div class="filter-menu filter-menu--form" data-dropdown-menu>
                    <label class="filter-label">Items per page</label>
                    <div class="filter-select-wrap">
                        <select name="Query.PageSize" class="filter-select">
                            <option value="10" selected="@(Model.Query.PageSize == 10)">10</option>
                            <option value="20" selected="@(Model.Query.PageSize == 20)">20</option>
                            <option value="30" selected="@(Model.Query.PageSize == 30)">30</option>
                            <option value="50" selected="@(Model.Query.PageSize == 50)">50</option>
                        </select>
                    </div>

                    <button type="submit" class="filter-apply">Apply</button>
                </div>
            </div>

            <a asp-page="./Products" class="filter-chip filter-chip--clear">Reset</a>
        </div>
    </form>

    @if (Model.Products?.Data == null || !Model.Products.Data.Any())
    {
        <section class="empty-state">
            <h2>No products found</h2>
            <p>There are no products available for the selected criteria.</p>
        </section>
    }
    else
    {
        <div class="product-list">
            @foreach (var product in Model.Products.Data)
            {
                <article class="product-card">
                    <div class="product-media" aria-hidden="true">
                        <img src="@product.ImageUrl"
                             alt="@product.Name"
                             class="product-media-image"
                             loading="lazy"
                             width="120"
                             height="120" />
                    </div>

                    <div class="product-main">
                        <div class="product-content">
                            <div class="product-topline">
                                <span class="product-category">@product.CategoryName</span>
                                <span class="product-rating">★ @product.Rating.ToString("0.0")</span>
                            </div>

                            <h2 class="product-name">@product.Name</h2>

                            <div class="product-bottom">
                                <div class="product-price-block">
                                    <span class="meta-label">Price</span>
                                    <strong class="product-price">@product.Price.ToString("0.00") zł</strong>
                                </div>

                                <form method="post" asp-page-handler="AddToCart" class="product-form js-add-to-cart-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@product.Id" />

                                    <div class="quantity-row">
                                        <div class="quantity-control">
                                            <button type="button" class="qty-btn qty-btn--minus" aria-label="Decrease quantity">–</button>

                                            <input type="number"
                                                   name="quantity"
                                                   class="qty-input"
                                                   value="1"
                                                   min="1"
                                                   max="999"
                                                   inputmode="numeric" />

                                            <button type="button" class="qty-btn qty-btn--plus" aria-label="Increase quantity">+</button>
                                        </div>

                                        <button type="submit" class="add-to-cart-btn">
                                            Add to cart
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </article>
            }
        </div>

        @if (Model.Products.Metadata is not null && Model.Products.Metadata.TotalPages > 1)
        {
            var previousRoute = new Dictionary<string, string?>(Model.CurrentRouteValues, StringComparer.OrdinalIgnoreCase);
            previousRoute["Query.PageNumber"] = (Model.Products.Metadata.CurrentPage - 1).ToString();

            var nextRoute = new Dictionary<string, string?>(Model.CurrentRouteValues, StringComparer.OrdinalIgnoreCase);
            nextRoute["Query.PageNumber"] = (Model.Products.Metadata.CurrentPage + 1).ToString();

            <nav class="pagination" aria-label="Products pagination">
                <a class="pagination-link @(Model.Products.Metadata.HasPrevious ? "" : "is-disabled")"
                   asp-page="./Products"
                   asp-all-route-data="previousRoute"
                   aria-disabled="@(!Model.Products.Metadata.HasPrevious)">
                    Previous
                </a>

                <div class="pagination-status">
                    Page <strong>@Model.Products.Metadata.CurrentPage</strong>
                    of <strong>@Model.Products.Metadata.TotalPages</strong>
                </div>

                <a class="pagination-link @(Model.Products.Metadata.HasNext ? "" : "is-disabled")"
                   asp-page="./Products"
                   asp-all-route-data="nextRoute"
                   aria-disabled="@(!Model.Products.Metadata.HasNext)">
                    Next
                </a>
            </nav>
        }
    }
</section>
@section Scripts {
    <script src="~/js/products-quantity.js" asp-append-version="true"></script>
}